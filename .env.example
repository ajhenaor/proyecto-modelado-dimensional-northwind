# Copy to .env and adjust. Used by scripts/load_env.sh before dbt commands.
# See README.md for Snowflake setup.
#
# Login caching:
# - dbt: use ./scripts/dbt.sh (not raw `dbt`) so the OAuth patch loads and optional token cache works.
# - snow: after one browser login, the CLI reuses its token store (e.g. macOS Keychain).

# OAuth browser flow (OAUTH_AUTHORIZATION_CODE):
# Wait time (seconds) for you to finish the browser redirect. Default in connector is 120;
# this project defaults to 600 via dbt_snowflake_oauth_patch.py unless you override:
# SNOWFLAKE_EXTERNAL_BROWSER_TIMEOUT=600
#
# If the browser shows "The requested scope is invalid", your IdP likely rejects the
# connector's optional `offline_access` scope. Leave the line below unset (default).
# Only set to 1 if your admin confirms refresh tokens / offline_access are allowed.
# SNOWFLAKE_OAUTH_ENABLE_REFRESH_TOKENS=1

# Rare: override OAuth scope (otherwise Snowflake uses session:role:<SNOWFLAKE_ROLE>).
# SNOWFLAKE_OAUTH_SCOPE=session:role:MYROLE

SNOWFLAKE_ACCOUNT=<your-snowflake-account-identifier>
SNOWFLAKE_USER=<your-snowflake-username>
SNOWFLAKE_ROLE=<your-snowflake-role>
SNOWFLAKE_WAREHOUSE=<your-warehouse>
SNOWFLAKE_DATABASE=NORTHWIND_DIMENSIONAL_DEV
SNOWFLAKE_SCHEMA=DBT

# --- Optional: non-browser dbt (profiles target dev_password) ---
# Unset SNOWFLAKE_PASSWORD to avoid accidental password auth; never commit .env.
# SNOWFLAKE_PASSWORD=
# Then: ./scripts/dbt.sh build --target dev_password
